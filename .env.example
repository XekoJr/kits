# Copy to .env and fill in real values before running:
#   docker compose up --build -d
# (docker-compose.yml is generated by copying docker-compose.yml.example)

# --- Laravel ---
APP_NAME=Kits
APP_ENV=production
# Generate with: docker compose run --rm backend php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

# --- PostgreSQL (shared by postgres + backend services) ---
POSTGRES_DB=kits
POSTGRES_USER=kits
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# --- Host port mappings ---
BACKEND_PORT=8000
FRONTEND_PORT=8080
